generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categories {
  id         Int         @id @default(autoincrement())
  nama       String      @db.VarChar(100)
  deskripsi  String?
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  finalists  finalists[]
  events     events[]
}

model finalists {
  id           Int            @id @default(autoincrement())
  no_urut      String         @db.VarChar(10)
  nama         String         @db.VarChar(100)
  asal_sekolah String         @db.VarChar(150)
  foto_url     String?
  category_id  Int
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  categories   categories     @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  votes        votes[]
  transactions transactions[]
  events       events[]
}

model tickets {
  id         Int       @id @default(autoincrement())
  code       String    @unique @db.VarChar(50)
  status     String    @default("active") @db.VarChar(20)
  user_id    Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  used_at    DateTime? @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  votes      votes[]
}

model users {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  password_hash String    @db.VarChar(255)
  role          String    @default("voter") @db.VarChar(20)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  tickets       tickets[]
  votes         votes[]
}

model votes {
  id          Int       @id @default(autoincrement())
  user_id     Int
  finalist_id Int
  ticket_id   Int
  voted_at    DateTime? @default(now()) @db.Timestamp(6)
  finalists   finalists @relation(fields: [finalist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tickets     tickets   @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model transactions {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(50)
  finalist_id Int
  votes_count Int
  amount      Float
  voter_email String    @db.VarChar(150)
  status      String    @default("pending") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  finalists   finalists @relation(fields: [finalist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  kode_unik   Int?
  grand_total Int?
}

model events {
  id           Int        @id @default(autoincrement())
  nama         String     @db.VarChar(150)
  lokasi       String     @db.VarChar(150)
  tanggal      DateTime   @db.Timestamp(6)
  deskripsi    String?
  category_id  Int
  pembicara_id Int
  created_at   DateTime?  @default(now()) @db.Timestamp(6)
  categories   categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  finalists    finalists  @relation(fields: [pembicara_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model qrcodes {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  image       String   @db.Text
  description String?  @db.Text
  status      String   @default("Aktif") @db.VarChar(20)
}
